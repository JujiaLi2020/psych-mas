# Copy to .env and fill in API keys (never commit .env).
#
# --- Docker Compose (UI in container) ---
# PSYMAS_BACKEND_URL is set automatically to http://backend:8000 in docker-compose.yml.
#
# --- Host Streamlit + Docker backend only ---
# Windows: use 9000 (port 8000 is often reserved by the OS — see docker-compose.yml)
# PSYMAS_BACKEND_URL=http://localhost:9000

OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# Optional: enable Redis profile for multi-worker backend
# docker compose --profile redis up --build
# REDIS_URL=redis://redis:6379/0
# PSYMAS_GUNICORN_WORKERS=4
